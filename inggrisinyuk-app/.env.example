DATABASE_URL="postgresql://USERNAME@localhost:5432/inggrisinyuk_dev?schema=public"
SESSION_SECRET="generate-with: openssl rand -base64 32"

APP_URL="http://localhost:3000"

# Google Cloud Console > OAuth Client (Web application)
# Authorized redirect URI harus sama persis dengan GOOGLE_REDIRECT_URI di bawah
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI="http://localhost:3000/api/auth/google/callback"

# Xendit Dashboard > Settings > API Keys & Webhooks
XENDIT_SECRET_KEY=
XENDIT_WEBHOOK_TOKEN=
